# Copy this file to a school-server-only location such as
# /etc/mesugak/kis-paper.env. Never commit the copied file.
MESUGAK_MARKET=KR
# Optional override. The school-server default is functions/.env.
MESUGAK_ENV_FILE=
MESUGAK_INITIAL_CASH=10000000
MESUGAK_BUY_SCORE_MIN=65.0
MESUGAK_SCORE_EXIT_THRESHOLD=-15.0
MESUGAK_TRAILING_STOP_PCT=0.08
MESUGAK_POSITION_WEIGHT=0.10
MESUGAK_ROTATION_SCORE_GAP=10.0
MESUGAK_MAX_LIVE_CANDIDATES=10
MESUGAK_QUOTE_DELAY_SECONDS=1.1
MESUGAK_QUOTE_RETRIES=2
MESUGAK_QUOTE_RATE_LIMIT_BACKOFF_SECONDS=2.0
MESUGAK_POLL_INTERVAL_SECONDS=60
MESUGAK_MARKET_START_TIME=09:00
MESUGAK_MARKET_END_TIME=15:35
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_PAPER_TOKEN_CACHE=/home/2023112374/mesugak/v2/runtime/kis/token.json
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_CANO=
KIS_PAPER_ACNT_PRDT_CD=
